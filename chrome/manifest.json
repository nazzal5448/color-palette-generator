{
  "manifest_version": 3,
  "name": "WebColor - Webpage Colors Extractor",
  "version": "1.0.0",
  "description": "Extract all active CSS colors from any webpage instantly. Save, inspect, and copy color palettes.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}
